# Copy to .env and fill in ( .env is gitignored ).
# Testing keys: configs/real.testing.yml (gitignored; see configs/real.testing.template.yml).
# Optional extra overrides: configs/real.yml (merged last).
# Never commit real keys.

# Polymarket CLOB relayer / builder (used when YAML fields are empty)
POLY_RELAYER_API_KEY=
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Limitless Exchange — https://api.limitless.exchange (used when YAML hft.limitless fields are empty)
LIMITLESS_API_KEY=
LIMITLESS_WALLET_ADDRESS=

# Predict.fun (used when YAML hft.predict_fun fields are empty)
# PREDICT_FUN_BASE_URL=
# PREDICT_FUN_API_KEY=
# PREDICT_FUN_PRIVATE_KEY=

# DFlow / Kalshi (used when YAML hft.kalshi_dflow fields are empty)
# DFLOW_BASE_URL=
# DFLOW_API_KEY=
# DFLOW_LIVE_EVENT_TICKER=
