# PredictOS Terminal Environment Variables
# Copy this file to .env and update the values if needed
#
# Runtime: use Bun only (bun install, bun run dev | build | start). No Node.js/npm required.
# Production server: run `bun run build` then `bun run start` (sets BUN_ENV=production).

# Optional: override path for GET /api/alpha-rules (defaults to ../strat/alpha-rules/data/alpha_rules.sqlite from server)
# ALPHA_RULES_DB=/absolute/path/to/alpha_rules.sqlite

# Assumed minutes between alpha-rules collector cron runs (Event Scanner "next scan" clock). Default 30 (see strat/alpha-rules/cron/scan.sh).
# ALPHA_RULES_SCAN_INTERVAL_MINUTES=30

# =========================================================================================
# OPENAI (terminal + strat/alpha-rules/description_agent.py)
# =========================================================================================
# description_agent.py loads this file automatically (repo terminal/.env) if present.
# Existing process env always wins (setdefault). For cron, same applies when Python runs.
# OPENAI_API_KEY=
# OpenAI-compatible API root (default https://api.openai.com/v1 → …/chat/completions)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Model for Agents page “Generate prompts” (POST /api/description-agent-strategies-expand)
# DESCRIPTION_AGENT_EXPAND_MODEL=gpt-4.1-mini

# =========================================================================================
# POLYBACK INTELLIGENCE (Go service in mm/polyback-mm, default :8085)
# =========================================================================================
# Bun /api/* routes proxy agent and market calls to this base URL.
INTELLIGENCE_BASE_URL=http://127.0.0.1:8085

# Optional: override full URL for a single route (defaults to INTELLIGENCE_BASE_URL + /api/intelligence/<name>)
# INTELLIGENCE_EDGE_FUNCTION_GET_EVENTS=http://127.0.0.1:8085/api/intelligence/get-events
# INTELLIGENCE_EDGE_FUNCTION_EVENT_ANALYSIS_AGENT=http://127.0.0.1:8085/api/intelligence/event-analysis-agent
# INTELLIGENCE_EDGE_FUNCTION_ANALYZE_EVENT_MARKETS=http://127.0.0.1:8085/api/intelligence/analyze-event-markets
# INTELLIGENCE_EDGE_FUNCTION_BOOKMAKER_AGENT=http://127.0.0.1:8085/api/intelligence/bookmaker-agent
# INTELLIGENCE_EDGE_FUNCTION_ARBITRAGE_FINDER=http://127.0.0.1:8085/api/intelligence/arbitrage-finder
# INTELLIGENCE_EDGE_FUNCTION_MAPPER_AGENT=http://127.0.0.1:8085/api/intelligence/mapper-agent
# INTELLIGENCE_EDGE_FUNCTION_POLYMARKET_PUT_ORDER=http://127.0.0.1:8085/api/intelligence/polymarket-put-order
# INTELLIGENCE_EDGE_FUNCTION_POLYFACTUAL_RESEARCH=http://127.0.0.1:8085/api/intelligence/polyfactual-research
# INTELLIGENCE_EDGE_FUNCTION_X402_SELLER=http://127.0.0.1:8085/api/intelligence/x402-seller
# INTELLIGENCE_EDGE_FUNCTION_BETTING_BOT=http://127.0.0.1:8085/api/intelligence/polymarket-up-down-15-markets-limit-order-bot
# INTELLIGENCE_EDGE_FUNCTION_POSITION_TRACKER=http://127.0.0.1:8085/api/intelligence/polymarket-position-tracker

# API keys and provider secrets belong on the intelligence process environment (see mm/polyback-mm/docs/API.md).


# =========================================================================================
# DOME API CONFIGURATION (for Wallet Tracking feature)
# =========================================================================================
# Get your API key from https://domeapi.io
DOME_API_KEY=your_dome_api_key_here


# =========================================================================================
# IRYS / VERIFIABLE ANALYSIS (terminal proxies to Go upload service)
# =========================================================================================
# Bun `/api/irys-upload` forwards to this base URL (no trailing slash required).
# Run the Go service: cd ../mm/irys-upload && go run ./cmd/irys-upload
IRYS_UPLOAD_SERVICE_URL=http://127.0.0.1:8091

# The variables below are NOT read by the Bun server; set them in the environment
# of the `mm/irys-upload` process (same values in one .env if you `source` it for both).
#
# IRYS_CHAIN_ENVIRONMENT=devnet   # or mainnet
# IRYS_SOLANA_PRIVATE_KEY=      # base58 keypair
# IRYS_SOLANA_RPC_URL=https://api.devnet.solana.com   # required for devnet
# PORT=8091                     # optional; Go listener port (match IRYS_UPLOAD_SERVICE_URL)
